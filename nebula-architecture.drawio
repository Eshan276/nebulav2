        </mxCell>

        <!-- tx_bytes detail box -->
        <mxCell id="txbytes-box" value="&lt;b&gt;tx_bytes (108 bytes) — what the user signs&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;[0..32]   contract_id  = [0,0,0,1] + contract_hash[0..28]&lt;br/&gt;[32..64]  pubkey_hash  = sha256(xmss_pk)&lt;br/&gt;[64..68]  wallet_nonce = LE u32&lt;br/&gt;[68..100] destination  = XDR.slice(4..36)&lt;br/&gt;[100..108] amount      = BE i64 stroops&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1628;strokeColor=#22d3ee;fontColor=#22d3ee;fontSize=10;arcSize=6;align=left;spacingLeft=10;" vertex="1" parent="1">
