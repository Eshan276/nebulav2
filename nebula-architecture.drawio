        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="zone-xmss" value="XMSS SIGNING LAYER  (Post-Quantum ✓)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.lean_mapping.electronic_info_flow_edge;strokeColor=#16a34a;fillColor=#f0fdf4;fontStyle=1;fontSize=13;fontColor=#16a34a;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="120" width="640" height="820" as="geometry" />
        </mxCell>

        <mxCell id="xmss-title" value="XMSS-SHA2_10_256" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#14532d;strokeColor=#22c55e;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="940" y="170" width="560" height="40" as="geometry" />
        </mxCell>

        <mxCell id="xmss-params" value="&lt;b&gt;Parameters (RFC 8391 / NIST SP 800-208)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;n = 32   (SHA-256 output, bytes)&lt;br/&gt;h = 10   (tree height → 1024 one-time keys)&lt;br/&gt;w = 16   (Winternitz parameter)&lt;br/&gt;len = 67 (WOTS+ chains: 64 msg + 3 checksum)&lt;br/&gt;d = 1    (single-layer hypertree)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#ffffff;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="230" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="xmss-sizes" value="&lt;b&gt;Key &amp; Signature Sizes&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;Public key:  68B = OID(4) + root(32) + pub_seed(32)&lt;br/&gt;Private key: large (full Merkle tree)&lt;br/&gt;Signature: 2500B&lt;br/&gt;  = idx(4) + r(32)&lt;br/&gt;  + wots_sig(67×32=2144)&lt;br/&gt;  + auth_path(10×32=320)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#ffffff;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1220" y="230" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- WOTS+ chain -->
        <mxCell id="wots-box" value="&lt;b&gt;WOTS+ Signing (67 chains)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;h_msg(r, root, idx, tx_bytes)&lt;br/&gt;→ 67 4-bit nibbles + 3 checksum nibbles&lt;br/&gt;Each chain: SHA-256 iterated (16-v) times forward&lt;br/&gt;Verification: iterated v times backward&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#ffffff;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="380" width="540" height="90" as="geometry" />
        </mxCell>

        <!-- Merkle tree -->
        <mxCell id="merkle-box" value="&lt;b&gt;Merkle Tree (h=10, 1024 leaves)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#14532d;strokeColor=#22c55e;fontColor=#ffffff;fontSize=11;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="500" width="540" height="30" as="geometry" />
        </mxCell>

