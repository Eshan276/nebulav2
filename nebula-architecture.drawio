        <!-- Sindri cloud -->
        <mxCell id="sindri-cloud" value="Sindri Cloud Proving" style="shape=mxgraph.cisco.sites.generic_building;fillColor=#4c1d95;strokeColor=#8b5cf6;fontColor=#ffffff;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1850" y="155" width="80" height="70" as="geometry" />
        </mxCell>
        <mxCell id="sindri-label" value="sindri.app" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#8b5cf6;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1830" y="225" width="120" height="20" as="geometry" />
        </mxCell>

        <!-- SP1 guest box -->
        <mxCell id="sp1-guest" value="&lt;b&gt;SP1 Guest Program (RISC-V ELF)&lt;/b&gt;&lt;br/&gt;sp1/program/src/main.rs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e1065;strokeColor=#8b5cf6;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1640" y="170" width="560" height="40" as="geometry" />
        </mxCell>

        <!-- Private inputs -->
        <mxCell id="sp1-inputs" value="&lt;b&gt;Private Inputs (SP1Stdin)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;bincode_vec_u8(pk)     → [u64_le_len || pk_bytes]&lt;br/&gt;bincode_vec_u8(tx)     → [u64_le_len || tx_bytes]&lt;br/&gt;bincode_vec_u8(sig)    → [u64_le_len || sig_bytes]&lt;br/&gt;JSON: {buffer: [pk,tx,sig], ptr:0, proofs:[]}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#8b5cf6;fontColor=#ffffff;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="230" width="340" height="110" as="geometry" />
        </mxCell>

        <!-- XMSS verifier -->
        <mxCell id="sp1-verifier" value="&lt;b&gt;XMSS Verifier (in-circuit, pure SHA-256)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e1065;strokeColor=#a78bfa;fontColor=#ffffff;fontSize=11;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1640" y="360" width="560" height="30" as="geometry" />
        </mxCell>

        <mxCell id="sp1-step1" value="&lt;b&gt;1. Parse signature&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;Extract idx, r, wots_sig[67], auth_path[10]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#7c3aed;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="405" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sp1-step2" value="&lt;b&gt;2. h_msg computation&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;buf[120..128] = idx_bytes  ← fixed offset&lt;br/&gt;SHA-256(padding || r || root || idx || M)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#7c3aed;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1930" y="405" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sp1-step3" value="&lt;b&gt;3. WOTS+ chain eval (67 chains)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;For each chain: SHA-256 iterated v times&lt;br/&gt;Recovers WOTS+ public key element&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#7c3aed;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="475" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sp1-step4" value="&lt;b&gt;4. L-tree → leaf hash&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;67 WOTS+ pk elements → single leaf&lt;br/&gt;Handles odd-length layers per RFC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#7c3aed;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1930" y="475" width="270" height="55" as="geometry" />
        </mxCell>
        <mxCell id="sp1-step5" value="&lt;b&gt;5. Auth path traversal (10 levels)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;leaf → ... → computed_root&lt;br/&gt;Assert: computed_root == pk.root&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#7c3aed;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="545" width="270" height="55" as="geometry" />
        </mxCell>

        <!-- Public outputs -->
        <mxCell id="sp1-outputs" value="&lt;b&gt;Public Values Committed (68 bytes)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;[0..32]  pubkey_hash  = sha256(pk_bytes)&lt;br/&gt;[32..64] tx_hash      = sha256(tx_bytes)&lt;br/&gt;[64..68] wallet_nonce = u32::from_le(tx_bytes[64..68])&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1040;strokeColor=#22d3ee;fontColor=#22d3ee;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="620" width="560" height="80" as="geometry" />
        </mxCell>

        <!-- Groth16 wrap -->
        <mxCell id="groth16-box" value="&lt;b&gt;Groth16 Wrap (BN254)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;pub_input[0] = program_vkey (Fr element)&lt;br/&gt;pub_input[1] = sha256(public_values) top-3-bits-zeroed&lt;br/&gt;Sindri circuit ID: 675b1311-8e2b-4b2c-9f16-44a548a3e2b7&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e1065;strokeColor=#a78bfa;fontColor=#ffffff;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="720" width="560" height="80" as="geometry" />
        </mxCell>

        <!-- proof_bytes detail -->
        <mxCell id="proof-bytes" value="&lt;b&gt;proof_bytes (260B)&lt;/b&gt;  +  &lt;b&gt;public_values (68B)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;proof_bytes: vkey_hash[0..4] + A(64B) + B(128B) + C(64B)&lt;br/&gt;B layout: X.c1||X.c0||Y.c1||Y.c0  (Soroban imaginary-first)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a40;strokeColor=#a78bfa;fontColor=#c4b5fd;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="820" width="560" height="70" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ZONE: RELAY SERVER -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="zone-relay" value="RELAY SERVER  (Docker / VM)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.lean_mapping.electronic_info_flow_edge;strokeColor=#d97706;fillColor=#fffbeb;fontStyle=1;fontSize=13;fontColor=#d97706;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="1010" width="1160" height="380" as="geometry" />
        </mxCell>

        <mxCell id="relay-server" value="&lt;b&gt;server.js&lt;/b&gt; (Node.js ESM, no deps)&lt;br/&gt;backend.iameshan.tech/relayer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#451a03;strokeColor=#f59e0b;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="1055" width="560" height="40" as="geometry" />
        </mxCell>

        <mxCell id="relay-post" value="&lt;b&gt;POST /withdraw&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;{ proof_bytes, public_values,&lt;br/&gt;  destination, amount_stroops }&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#292524;strokeColor=#f59e0b;fontColor=#ffffff;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1115" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="relay-health" value="&lt;b&gt;GET /health&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;{ ok: true }&lt;br/&gt;liveness check&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#292524;strokeColor=#f59e0b;fontColor=#ffffff;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="1115" width="260" height="70" as="geometry" />
        </mxCell>

        <mxCell id="relay-stellar" value="&lt;b&gt;stellar contract invoke withdraw&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;--network testnet --id &lt;CONTRACT&gt;&lt;br/&gt;-- withdraw --proof_bytes &lt;260B hex&gt;&lt;br/&gt;   --public_values &lt;68B hex&gt;&lt;br/&gt;   --destination &lt;G...&gt; --amount &lt;stroops&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c1200;strokeColor=#f59e0b;fontColor=#fbbf24;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="1210" width="560" height="100" as="geometry" />
        </mxCell>

        <mxCell id="relay-why" value="⚠️  Why relay?  Soroban testnet RPC disables BN254 pairing in simulateTransaction → UnreachableCodeReached.&lt;br/&gt;stellar contract invoke runs the WASM VM locally with full host functions, bypassing simulation.&lt;br/&gt;Relay CANNOT redirect funds — destination is cryptographically bound in the proof." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c1200;strokeColor=#d97706;fontColor=#fde68a;fontSize=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="1330" width="560" height="50" as="geometry" />
        </mxCell>

        <!-- Docker -->
        <mxCell id="docker-box" value="&lt;b&gt;Dockerfile&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;FROM node:22-slim&lt;br/&gt;stellar CLI v23.4.1 (aarch64)&lt;br/&gt;entrypoint.sh: stellar keys add relayer --secret-key&lt;br/&gt;ENV RELAYER_SECRET, WALLET_CONTRACT, STELLAR_ACCOUNT&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c2a3a;strokeColor=#38bdf8;fontColor=#7dd3fc;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="1055" width="480" height="110" as="geometry" />
        </mxCell>

        <mxCell id="relay-trust" value="&lt;b&gt;Trust Model:&lt;/b&gt; Relay holds Stellar key for gas fees only.&lt;br/&gt;Cannot steal funds. Can censor (availability risk). No user key material stored." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c1500;strokeColor=#d97706;fontColor=#fde68a;fontSize=10;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="700" y="1185" width="480" height="50" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ZONE: SOROBAN CONTRACT -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="zone-soroban" value="SOROBAN SMART CONTRACT  (Stellar Testnet)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.lean_mapping.electronic_info_flow_edge;strokeColor=#0891b2;fillColor=#ecfeff;fontStyle=1;fontSize=13;fontColor=#0891b2;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1280" y="1010" width="1060" height="380" as="geometry" />
        </mxCell>

        <mxCell id="contract-title" value="XmssWallet Contract  ·  CCQ4R5FTHPDBGPMYEWEDRKZMHWHYN4QB26DRTZCM4MICARWNLJK56Q6B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=11;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1055" width="980" height="36" as="geometry" />
        </mxCell>

        <!-- Storage -->
        <mxCell id="storage-box" value="&lt;b&gt;Contract Storage&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;ProgramVKey  → BytesN&lt;32&gt;  (set at init)&lt;br/&gt;XlmToken     → Address     (XLM SAC)&lt;br/&gt;Balance(hash)→ i128 stroops&lt;br/&gt;Nonce(hash)  → u32&lt;/font&gt;" style="shape=mxgraph.flowchart.stored_data;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#67e8f9;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1105" width="280" height="110" as="geometry" />
        </mxCell>

        <!-- withdraw() -->
        <mxCell id="withdraw-fn" value="&lt;b&gt;withdraw()&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2a3a;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1100" width="660" height="30" as="geometry" />
        </mxCell>

        <mxCell id="w-check1" value="&lt;b&gt;① Nonce check&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;proof_nonce == storage.nonce[pubkey_hash]&lt;br/&gt;Prevents replay attacks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1145" width="155" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w-check2" value="&lt;b&gt;② tx_hash check&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;sha256(rebuild_tx_bytes(...)) ==&lt;br/&gt;proof_tx_hash&lt;br/&gt;Binds dest + amount&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1808" y="1145" width="155" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w-check3" value="&lt;b&gt;③ Groth16 verify&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;BN254 pairing check&lt;br/&gt;e(A,B)·e(α,β)·e(vk_x,γ)·e(C,δ)==1&lt;br/&gt;Hardcoded VK constants&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1975" y="1145" width="155" height="65" as="geometry" />
        </mxCell>
        <mxCell id="w-check4" value="&lt;b&gt;④ Balance check&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;balance[pubkey_hash] &gt;= amount&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="2143" y="1145" width="155" height="65" as="geometry" />
        </mxCell>

        <!-- State transition -->
        <mxCell id="state-transition" value="&lt;b&gt;State Transition (atomic)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;balance[pubkey_hash] -= amount&lt;br/&gt;nonce[pubkey_hash]  += 1&lt;br/&gt;xlm_token.transfer(contract → destination, amount)&lt;br/&gt;emit WithdrawEvent { pubkey_hash, destination, amount, new_balance, new_nonce }&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c2a1a;strokeColor=#22c55e;fontColor=#86efac;fontSize=11;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1640" y="1230" width="660" height="90" as="geometry" />
        </mxCell>

        <!-- deposit + other fns -->
        <mxCell id="other-fns" value="&lt;b&gt;deposit(from, pubkey_hash, amount)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;Soroban auth → transfer XLM to contract → balance += amount&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;b&gt;balance(pubkey_hash) / nonce(pubkey_hash)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;View functions — no state change&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0c1a20;strokeColor=#22d3ee;fontColor=#ffffff;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1235" width="290" height="110" as="geometry" />
        </mxCell>

        <!-- VK constants -->
        <mxCell id="vk-box" value="&lt;b&gt;Hardcoded VK (SP1 v4.0.0-rc.3)&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;ALPHA_G1(64B) · BETA_NEG_G2(128B)&lt;br/&gt;GAMMA_NEG_G2(128B) · DELTA_NEG_G2(128B)&lt;br/&gt;IC[0](64B) · IC[1](64B) · IC[2](64B)&lt;br/&gt;vk_x = IC[0] + input0·IC[1] + input1·IC[2]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0a40;strokeColor=#a78bfa;fontColor=#c4b5fd;fontSize=10;arcSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1320" y="1340" width="290" height="30" as="geometry" />
        </mxCell>

        <!-- Stellar network -->
        <mxCell id="stellar-net" value="Stellar Testnet&lt;br/&gt;&lt;font color='#aaaaaa'&gt;XLM SAC: CDLZFC3S...HHGCYSC&lt;br/&gt;soroban-testnet.stellar.org&lt;/font&gt;" style="shape=mxgraph.cisco.sites.generic_building;fillColor=#1e3a5f;strokeColor=#38bdf8;fontColor=#7dd3fc;fontSize=11;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2180" y="1270" width="120" height="80" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- DATA FLOW ARROWS — main path -->
        <!-- ═══════════════════════════════════════════════════════ -->

        <!-- 1. User clicks Send → tx_bytes built -->
        <mxCell id="flow1" value="① build tx_bytes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#8b5cf6;strokeWidth=2;fontColor=#8b5cf6;fontSize=10;fontStyle=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="bg-ts" target="xmss-params">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="290" />
              <mxPoint x="800" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 2. tx_bytes → XMSS sign -->
        <mxCell id="flow2" value="② xmss_sign(sk, tx_hex, leaf_idx)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#22c55e;strokeWidth=2;fontColor=#22c55e;fontSize=10;fontStyle=1;" edge="1" parent="1" source="txbytes-box" target="proof-inputs">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="430" y="870" />
              <mxPoint x="860" y="870" />
              <mxPoint x="860" y="795" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 3. proof_inputs → Sindri -->
        <mxCell id="flow3" value="③ POST /circuit/{id}/prove" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#a78bfa;strokeWidth=2;fontColor=#a78bfa;fontSize=10;fontStyle=1;" edge="1" parent="1" source="proof-inputs" target="sp1-inputs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. Sindri → proof_bytes -->
        <mxCell id="flow4" value="④ Groth16 proof (260B + 68B)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#a78bfa;strokeWidth=2;fontColor=#a78bfa;fontSize=10;fontStyle=1;" edge="1" parent="1" source="groth16-box" target="proof-bytes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5. proof_bytes → relay -->
        <mxCell id="flow5" value="⑤ HTTPS POST proof + dest + amount" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f59e0b;strokeWidth=2;fontColor=#f59e0b;fontSize=10;fontStyle=1;" edge="1" parent="1" source="proof-bytes" target="relay-post">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1210" y="855" />
              <mxPoint x="1210" y="1150" />
              <mxPoint x="230" y="1150" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 6. relay → stellar contract invoke -->
        <mxCell id="flow6" value="⑥ stellar contract invoke" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#f59e0b;strokeWidth=2;fontColor=#f59e0b;fontSize=10;fontStyle=1;" edge="1" parent="1" source="relay-post" target="relay-stellar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7. relay → soroban contract -->
        <mxCell id="flow7" value="⑦ invoke withdraw()" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#22d3ee;strokeWidth=2;fontColor=#22d3ee;fontSize=10;fontStyle=1;" edge="1" parent="1" source="relay-stellar" target="withdraw-fn">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="1350" />
              <mxPoint x="380" y="1420" />
              <mxPoint x="1970" y="1420" />
              <mxPoint x="1970" y="1130" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 8. contract → stellar network (XLM transfer) -->
        <mxCell id="flow8" value="⑧ XLM transfer" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#22c55e;strokeWidth=2;fontColor=#22c55e;fontSize=10;fontStyle=1;" edge="1" parent="1" source="state-transition" target="stellar-net">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- NONCE / REPLAY PROTECTION CALLOUT -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="nonce-design" value="&lt;b&gt;Nonce / Leaf-Index Decoupling&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;wallet_nonce  → on-chain replay protection (increments only on SUCCESS)&lt;br/&gt;XMSS leaf_idx → internal to signature scheme (increments every sign attempt)&lt;br/&gt;&lt;br/&gt;Failed tx: burns one XMSS leaf, does NOT advance wallet_nonce.&lt;br/&gt;Recovery:  re-sign with next leaf, same wallet_nonce → new valid proof.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1628;strokeColor=#f59e0b;fontColor=#fde68a;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1440" width="760" height="110" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SECURITY PROPERTIES LEGEND -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="sec-legend" value="&lt;b&gt;Security Properties&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#8b5cf6;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1440" width="760" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sec1" value="✅  Post-quantum signing (XMSS SHA-256 basis, 2^128 quantum security)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#86efac;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1484" width="760" height="28" as="geometry" />
        </mxCell>
        <mxCell id="sec2" value="✅  Destination/amount bound in proof — relay cannot redirect funds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#86efac;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1516" width="760" height="28" as="geometry" />
        </mxCell>
        <mxCell id="sec3" value="✅  Replay protection via independent wallet nonce" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e16;strokeColor=#22c55e;fontColor=#86efac;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1548" width="760" height="28" as="geometry" />
        </mxCell>
        <mxCell id="sec4" value="⚠️  BN254 (Groth16) broken by Shor's — same gap as every ZK project today" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d1515;strokeColor=#ef4444;fontColor=#fca5a5;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1580" width="760" height="28" as="geometry" />
        </mxCell>
        <mxCell id="sec5" value="🔮  Fix path: Soroban Poseidon host fns (live Jan 2026) → STARK verifier in contract" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c1200;strokeColor=#f59e0b;fontColor=#fde68a;fontSize=11;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="880" y="1612" width="760" height="28" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- STACK SUMMARY TABLE -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <mxCell id="stack-title" value="&lt;b&gt;Stack Summary&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#8b5cf6;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1700" y="1440" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="stack1" value="Signing        XMSS-SHA2_10_256 (RFC 8391 / NIST SP 800-208)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#e0e0e0;" vertex="1" parent="1">
          <mxGeometry x="1700" y="1478" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="stack2" value="ZK proving     SP1 (Succinct) RISC-V zkVM" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#e0e0e0;" vertex="1" parent="1">
          <mxGeometry x="1700" y="1500" width="600" height="20" as="geometry" />
        </mxCell>
        <mxCell id="stack3" value="Proof system   Groth16 on BN254" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#e0e0e0;" vertex="1" parent="1">
          <mxGeometry x="1700" y="1522" width="600" height="20" as="geometry" />
        </mxCell>
