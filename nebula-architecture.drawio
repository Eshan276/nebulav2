        <mxCell id="zone-sp1" value="ZK PROVING LAYER  (SP1 + Sindri)" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];shape=mxgraph.lean_mapping.electronic_info_flow_edge;strokeColor=#7c3aed;fillColor=#f5f3ff;fontStyle=1;fontSize=13;fontColor=#7c3aed;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="1600" y="120" width="740" height="820" as="geometry" />
