        <mxCell id="xmss-security" value="🔒  Security: 2^128 quantum (Grover on SHA-256)&lt;br/&gt;Stateful: next_index must never be reused" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1c3a1c;strokeColor=#22c55e;fontColor=#86efac;fontSize=11;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="690" width="540" height="50" as="geometry" />
        </mxCell>

        <mxCell id="proof-inputs" value="&lt;b&gt;proof_inputs.json&lt;/b&gt;&lt;br/&gt;&lt;font color='#aaaaaa'&gt;pk (68B hex) · tx_bytes (108B hex) · sig (2500B hex)&lt;br/&gt;wallet_nonce (from tx_bytes[64..68])&lt;/font&gt;" style="shape=mxgraph.android.phone2;strokeColor=#22c55e;fillColor=#052e16;fontColor=#22c55e;fontSize=11;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="760" width="540" height="70" as="geometry" />
